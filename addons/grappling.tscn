[gd_scene format=4 uid="uid://csxicr2s7p5uv"]

[sub_resource type="GDScript" id="GDScript_xoaqq"]
resource_name = "Grappling"
script/source = "extends Area3D

var target_hit = false
var stop_all = false
var start_pos

func _physics_process(delta: float) -> void:
		
	if Input.is_action_just_released(\"MouseRight\"):
		stop_all = true
		var current_pos = get_parent().global_position
		get_parent().velocity += (current_pos - start_pos) * 2
		
		get_parent().is_grappling = false
		queue_free()
		
	if $RayCast3D.is_colliding():
		if stop_all == true:
			return
		target_hit = true
		get_parent().grappling_pos = global_position
		get_parent().is_grappling = true
		return
	else:
		global_position = global_transform.origin + -global_transform.basis.z * 1.2
		start_pos = get_parent().global_position
	
"

