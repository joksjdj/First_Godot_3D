[gd_scene format=3 uid="uid://dv2msq6yyblnq"]

[ext_resource type="PackedScene" uid="uid://cjqfnwuvkmgvf" path="res://addons/enemy.tscn" id="1_hsc1s"]

[sub_resource type="GDScript" id="GDScript_noarx"]
script/source = "extends Node3D

@export var enemy_to_spawn: PackedScene

# Called when the node enters the scene tree for the first time.
func _ready() -> void:
	var spawn = get_parent().get_node(\"Area3D\").get_node(\"SpawnPoint\")
	
	var points = spawn.get_children()
	points.shuffle()

	for i in range(7):
		if points.is_empty():
			break

		var enemy = enemy_to_spawn.instantiate()
		var random_spawn = points.pop_back()  # removes AND returns last element

		add_child(enemy)
		enemy.global_position = random_spawn.global_position
		random_spawn.queue_free()
"

[node name="Enemies" type="Node3D" unique_id=1916064014]
script = SubResource("GDScript_noarx")
enemy_to_spawn = ExtResource("1_hsc1s")
