[gd_scene format=3 uid="uid://dc8eu8t0twpix"]

[sub_resource type="GDScript" id="GDScript_xmp5n"]
script/source = "extends Area3D

func _physics_process(delta: float) -> void:
	if $RayCast3D.is_colliding():
		var hit = $RayCast3D.get_collider()
		if hit.name == \"MainPlayer\":
			hit.health -= 1
			print(\"Hit:\", hit.name, \"| Health:\", hit.health)
		elif hit.name == \"Enemy\":
			hit.follow_player = true
			hit.health -= 1
			var all_hearts = hit.get_node(\"Sprite3D\").get_node(\"SubViewport\").get_node(\"Node2D\")
			var heart = all_hearts.get_child(all_hearts.get_child_count() - 1)
			heart.queue_free()
			print(\"Hit:\", hit.name, \"| Health:\", hit.health)
		else:
			print(\"Hit:\", hit.name, \"|\", hit)
		queue_free()
	
	global_position = global_transform.origin + -global_transform.basis.z * 0.9
"

