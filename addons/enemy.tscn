[sub_resource type="GDScript" id="GDScript_upa07"]
resource_name = "Enemy"
script/source = "extends CharacterBody3D

var health = 3
@onready var Head = $Head
@onready var cooldown = 0
@onready var detect_player: bool = false
@onready var walk_path: PathFollow3D
var follow_player: bool = false
var player: CharacterBody3D

func _ready():
	while true:
		await get_tree().create_timer(1.0).timeout
		cooldown -= 1
	
func _unhandled_input(event: InputEvent) -> void:
	if Input.is_key_pressed(KEY_ESCAPE):
		queue_free()
		
func _physics_process(delta: float) -> void:
	if not is_on_floor():
		velocity += get_gravity() * delta
		
	if health < 1:
		get_tree().current_scene.get_node(\"Enemies\").enemies_left -= 1
		get_tree().current_scene.get_node(\"Enemies\").score += 1
		queue_free()
		
	move_and_slide()
	
	if detect_player or follow_player:
		player = get_tree().current_scene.get_node_or_null(\"MainPlayer\")
		if player:
			Head.look_at(player.get_node(\"Head\").global_position, Vector3.UP)
			global_rotation.y = Head.global_rotation.y
			
		if detect_player:
			if $Head/Aim.is_colliding():
				var hit = $Head/Aim.get_collider()
				if hit:
					if hit.name == \"MainPlayer\" and cooldown < 1:
						cooldown = 2
						spawn_bullet()
		elif follow_player:
			global_position = global_transform.origin + -global_transform.basis.z * 0.3
	else:
		walk_path.progress += 4 * delta
		var t = walk_path.global_transform
		var pos = global_transform.origin
		pos.x = t.origin.x
		pos.z = t.origin.z
		global_transform.origin = pos
			
		Head.global_rotation.y = walk_path.global_rotation.y
		global_rotation.y = Head.global_rotation.y
	
	
@export var object_to_spawn: PackedScene
func spawn_bullet():
	var obj = object_to_spawn.instantiate()
	add_child(obj)
	obj.global_transform.basis = Head.global_transform.basis.orthonormalized()
	obj.global_position = Head.global_transform.origin + -Head.global_transform.basis.z
	

func _on_area_3d_body_entered(body) -> void:
	print(\"In range\")
	detect_player = true
	follow_player = true
func _on_area_3d_body_exited(body) -> void:
	print(\"Out of range\")
	detect_player = false

func rotate_detected() -> void:
	var t = global_transform
	t.basis = Head.global_transform.basis.rotated(Vector3.UP, deg_to_rad(5))
	global_transform = t
"

