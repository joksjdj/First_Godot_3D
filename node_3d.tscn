[sub_resource type="GDScript" id="GDScript_a202f"]
resource_name = "StartMenu"
script/source = "extends Area2D

@export var character_to_spawn: PackedScene

var keybind_name = \"none\"
var keybind

func _ready() -> void:
	Engine.max_fps = 30
	
	var mode = $Control/Settings/window/display/OptionButton.selected
	select_display_mode(mode)

func _on_play_button_up():
	print(\"Play pressed\")
	var character = character_to_spawn.instantiate()
	get_parent().add_child(character)
	visible = false
	Control.MOUSE_FILTER_IGNORE


func _on_fps_value_changed(value: int) -> void:
	var fps_container = $Control/Settings/fps/text/value
	fps_container.text = str(value)
	Engine.max_fps = value
	print(Engine.max_fps)
	
func _input(event):
	if event is InputEventKey and event.pressed:
		if keybind_name != \"none\":
			keybind.text = str(event.as_text())
			print(event)
			
			InputMap.action_erase_events(keybind_name)
			var ev := InputEventKey.new()
			ev.keycode = event.keycode
			InputMap.action_add_event(keybind_name, ev)
			
			keybind_name = \"none\"
			

func _on_keybind_pressed(source_node) -> void:
	keybind_name = source_node.get_parent().name
	keybind = source_node
	print(keybind_name)


func _on_vsync_button_pressed(source: BaseButton) -> void:
	if DisplayServer.window_get_vsync_mode() == DisplayServer.VSYNC_ENABLED:
		DisplayServer.window_set_vsync_mode(DisplayServer.VSYNC_DISABLED)
		source.text = \"OFF\"
	else:
		DisplayServer.window_set_vsync_mode(DisplayServer.VSYNC_ENABLED)
		source.text = \"ON\"


func _on_resolution_selected(index: int, source: BaseButton) -> void:
	var res = int(source.text)
	var short
	if res == 3840:
		short =  res * (9.0 / 16)
		get_viewport().content_scale_size  = Vector2i(res, short)
	else:
		short =  res * (16.0 / 9)
		get_viewport().content_scale_size  = Vector2i(short, res)
	print(get_window().content_scale_size)


func select_display_mode(index: int):
	if index == 0:
		DisplayServer.window_set_mode(DisplayServer.WINDOW_MODE_FULLSCREEN)
	elif index == 1:
		DisplayServer.window_set_mode(DisplayServer.WINDOW_MODE_MAXIMIZED)
	elif index == 2:
		DisplayServer.window_set_mode(DisplayServer.WINDOW_MODE_WINDOWED)
		DisplayServer.window_set_flag(DisplayServer.WINDOW_FLAG_BORDERLESS, false)
	
func _on_option_button_item_selected(index: int) -> void:
	select_display_mode(index)


func _on_quit_pressed() -> void:
	get_tree().quit()
"

